<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Deriv Synthetic Indices Scanner</title>
<style>
/* ==========================================================================
   0. RESET & TOKENS
   ========================================================================== */
*, *::before, *::after { box-sizing: border-box; }
html, body { height: 100%; }
body {
  margin: 0;
  background: var(--bg-0);
  color: var(--text-0);
  font-family: var(--font-ui);
  font-size: 13px;
  line-height: 1.4;
  -webkit-font-smoothing: antialiased;
  overflow: hidden;
}
ul, ol { list-style: none; margin: 0; padding: 0; }
button, input, select { font-family: inherit; font-size: inherit; color: inherit; }
button { cursor: pointer; }
a { color: inherit; }
::-webkit-scrollbar { width: 10px; height: 10px; }
::-webkit-scrollbar-track { background: var(--bg-1); }
::-webkit-scrollbar-thumb { background: var(--border-light); border-radius: 6px; border: 2px solid var(--bg-1); }

:root{
  /* Color */
  --bg-0: #0a0d13;
  --bg-1: #10141d;
  --bg-2: #161b26;
  --bg-3: #1e2430;
  --bg-3-hover: #262d3d;
  --border: #232936;
  --border-light: #333a4a;
  --text-0: #e6e9ef;
  --text-1: #a7adba;
  --text-2: #666e7d;
  --accent: #00d4ff;
  --accent-dim: #0891b2;
  --accent-soft: rgba(0, 212, 255, 0.12);
  --violet: #8b7cff;
  --violet-soft: rgba(139, 124, 255, 0.14);
  --bull: #26a69a;
  --bull-soft: rgba(38, 166, 154, 0.14);
  --bear: #ef5350;
  --bear-soft: rgba(239, 83, 80, 0.14);
  --warn: #f0b429;
  --warn-soft: rgba(240, 180, 41, 0.14);

  /* Type */
  --font-ui: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  --font-mono: "SFMono-Regular", "Cascadia Code", Consolas, "Liberation Mono", Menlo, monospace;

  /* Layout */
  --header-h: 52px;
  --statusbar-h: 28px;
  --sidebar-w: 208px;
  --sidebar-w-collapsed: 56px;
  --radius-sm: 4px;
  --radius-md: 8px;
  --transition: 150ms ease;
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: 0.001ms !important; animation-iteration-count: 1 !important; transition-duration: 0.001ms !important; }
}

/* Light theme palette - swapped in via [data-theme="light"] on <html>.
   Same variable names/roles as the dark palette above, so every component
   that already themes off var(--bg-*)/var(--text-*)/etc. re-themes for free. */
:root[data-theme="light"]{
  --bg-0: #f4f6f9;
  --bg-1: #ffffff;
  --bg-2: #eef1f6;
  --bg-3: #e3e7ee;
  --bg-3-hover: #d7dce6;
  --border: #dde2ea;
  --border-light: #c7cedb;
  --text-0: #171a21;
  --text-1: #565e6e;
  --text-2: #8891a1;
  --accent: #0891b2;
  --accent-dim: #0e7490;
  --accent-soft: rgba(8, 145, 178, 0.12);
  --violet: #6d5ce6;
  --violet-soft: rgba(109, 92, 230, 0.12);
  --bull: #1f8f7f;
  --bull-soft: rgba(31, 143, 127, 0.12);
  --bear: #d9463f;
  --bear-soft: rgba(217, 70, 63, 0.12);
  --warn: #b5820a;
  --warn-soft: rgba(181, 130, 10, 0.14);
}

/* ==========================================================================
   1. LOADING SCREEN
   ========================================================================== */
.loading-screen {
  position: fixed; inset: 0; z-index: 9999;
  display: flex; align-items: center; justify-content: center;
  background: var(--bg-0);
  transition: opacity 400ms ease, visibility 400ms ease;
}
.loading-screen.is-hidden { opacity: 0; visibility: hidden; pointer-events: none; }
.loading-content { display: flex; flex-direction: column; align-items: center; gap: 18px; width: 280px; }
.loading-logo { position: relative; width: 64px; height: 64px; }
.loading-logo svg { width: 100%; height: 100%; }
.loading-logo .sweep {
  transform-origin: 32px 32px;
  animation: sweep-rotate 1.6s linear infinite;
}
@keyframes sweep-rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
.loading-title {
  font-size: 18px; letter-spacing: 2px; font-weight: 600; color: var(--text-0);
}
.loading-title span { color: var(--accent); font-weight: 700; }
.loading-status {
  font-family: var(--font-mono); font-size: 11px; color: var(--text-2);
  height: 14px; text-align: center;
}
.loading-bar { width: 100%; height: 3px; background: var(--bg-2); border-radius: 2px; overflow: hidden; }
.loading-bar-fill {
  height: 100%; width: 0%; background: linear-gradient(90deg, var(--accent-dim), var(--accent));
  transition: width 220ms ease;
}

/* ==========================================================================
   2. APP SHELL
   ========================================================================== */
.app { height: 100%; display: flex; flex-direction: column; }
.app[hidden] { display: none; }

.header {
  height: var(--header-h); flex: 0 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 14px; background: var(--bg-1); border-bottom: 1px solid var(--border);
  gap: 16px;
}
.header-left, .header-right { display: flex; align-items: center; gap: 12px; }
.header-center { flex: 1; display: flex; justify-content: center; min-width: 0; }

.icon-btn {
  display: inline-flex; align-items: center; justify-content: center;
  width: 30px; height: 30px; background: transparent; border: 1px solid transparent;
  border-radius: var(--radius-sm); color: var(--text-1); transition: background var(--transition), color var(--transition);
}
.icon-btn:hover { background: var(--bg-3); color: var(--text-0); }
.icon-btn svg { width: 16px; height: 16px; }

.brand { display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 14px; letter-spacing: 0.3px; white-space: nowrap; }
.brand-mark {
  width: 9px; height: 9px; border-radius: 50%;
  background: var(--accent); box-shadow: 0 0 8px var(--accent);
}
.brand-accent { color: var(--accent); }

.market-status {
  display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-1);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.market-status .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--bull); flex: 0 0 auto; }

.connection-indicator {
  display: flex; align-items: center; gap: 7px; padding: 5px 10px;
  border-radius: 999px; background: var(--bg-2); border: 1px solid var(--border);
  font-size: 11.5px; white-space: nowrap;
}
.conn-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--text-2); position: relative; }
.connection-indicator[data-status="connecting"] .conn-dot { background: var(--warn); animation: pulse 1s ease-in-out infinite; }
.connection-indicator[data-status="connected"] .conn-dot { background: var(--bull); box-shadow: 0 0 6px var(--bull); }
.connection-indicator[data-status="error"] .conn-dot,
.connection-indicator[data-status="disconnected"] .conn-dot { background: var(--bear); }
.connection-indicator[data-status="idle"] .conn-dot { background: var(--text-2); }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.35; } }
.conn-label { color: var(--text-1); }

.header-clock { font-family: var(--font-mono); font-size: 12px; color: var(--text-2); white-space: nowrap; }

/* ==========================================================================
   3. BODY LAYOUT: SIDEBAR + MAIN + SETTINGS DRAWER
   ========================================================================== */
.body-layout { flex: 1; display: flex; min-height: 0; position: relative; }

.sidebar {
  flex: 0 0 auto; width: var(--sidebar-w);
  background: var(--bg-1); border-right: 1px solid var(--border);
  display: flex; flex-direction: column; padding: 10px 8px;
  transition: width var(--transition);
  overflow-x: hidden; white-space: nowrap;
}
.sidebar.is-collapsed { width: var(--sidebar-w-collapsed); }
.nav-section-label {
  font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-2);
  padding: 10px 10px 6px;
}
.sidebar.is-collapsed .nav-section-label { opacity: 0; }
.nav-item {
  display: flex; align-items: center; gap: 10px; width: 100%;
  padding: 9px 10px; background: transparent; border: none; border-radius: var(--radius-sm);
  color: var(--text-1); font-size: 12.5px; text-align: left; margin-bottom: 2px;
  transition: background var(--transition), color var(--transition);
}
.nav-item svg { width: 16px; height: 16px; flex: 0 0 auto; }
.nav-item:hover { background: var(--bg-3); color: var(--text-0); }
.nav-item.is-active { background: var(--accent-soft); color: var(--accent); }
.nav-item .nav-badge {
  margin-left: auto; font-family: var(--font-mono); font-size: 10px; padding: 1px 6px;
  border-radius: 999px; background: var(--bg-3); color: var(--text-1);
}
.nav-item.is-active .nav-badge { background: rgba(0,212,255,0.18); color: var(--accent); }
.sidebar.is-collapsed .nav-label, .sidebar.is-collapsed .nav-badge { display: none; }
.nav-spacer { flex: 1; }
.sidebar-footer { padding: 8px 10px; font-size: 10px; color: var(--text-2); font-family: var(--font-mono); }
.sidebar.is-collapsed .sidebar-footer { display: none; }

.main { flex: 1; min-width: 0; display: flex; flex-direction: column; overflow: hidden; background: var(--bg-0); }

.panel { flex: 1; min-height: 0; display: flex; flex-direction: column; padding: 14px; overflow: hidden; }
.panel[hidden] { display: none; }

.panel-toolbar {
  display: flex; align-items: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap;
}
.panel-title { font-size: 14px; font-weight: 600; color: var(--text-0); margin-right: auto; display: flex; align-items: center; gap: 8px; }
.panel-title .count-pill {
  font-family: var(--font-mono); font-size: 10.5px; color: var(--text-1); background: var(--bg-2);
  border: 1px solid var(--border); padding: 1px 7px; border-radius: 999px;
}

.input, .select {
  background: var(--bg-2); border: 1px solid var(--border); color: var(--text-0);
  border-radius: var(--radius-sm); padding: 6px 10px; outline: none; transition: border-color var(--transition);
}
.input:focus, .select:focus { border-color: var(--accent-dim); }
.input::placeholder { color: var(--text-2); }
.search-input { width: 220px; }

.btn {
  display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px;
  background: var(--bg-2); border: 1px solid var(--border); color: var(--text-1);
  border-radius: var(--radius-sm); font-size: 12px; font-weight: 500;
  transition: background var(--transition), color var(--transition), border-color var(--transition);
}
.btn:hover { background: var(--bg-3); color: var(--text-0); }
.btn-primary { background: var(--accent-soft); border-color: rgba(0,212,255,0.35); color: var(--accent); }
.btn-primary:hover { background: rgba(0,212,255,0.2); }
.btn-danger { color: var(--bear); }
.btn-sm { padding: 4px 9px; font-size: 11px; }
.btn svg { width: 13px; height: 13px; }

/* Panel body / table */
.panel-body { flex: 1; min-height: 0; overflow: auto; border: 1px solid var(--border); border-radius: var(--radius-md); background: var(--bg-1); }

table.data-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
.data-table thead th {
  position: sticky; top: 0; z-index: 1;
  background: var(--bg-2); color: var(--text-2); text-align: left; font-weight: 600;
  font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.5px;
  padding: 9px 12px; border-bottom: 1px solid var(--border); white-space: nowrap;
}
.data-table tbody td { padding: 8px 12px; border-bottom: 1px solid var(--border); color: var(--text-0); white-space: nowrap; }
.data-table tbody tr:hover { background: var(--bg-2); }
.data-table tbody tr:last-child td { border-bottom: none; }

/* Momentary highlight applied to a row when its symbol produces a triggered
   entry signal (see AlertsManager's "alerts:row-highlight" event). */
@keyframes row-signal-flash {
  0% { background-color: rgba(38, 166, 154, 0.38); }
  100% { background-color: transparent; }
}
.data-table tbody tr.row-signal-flash td { animation: row-signal-flash 2.4s ease-out; }
.cell-mono { font-family: var(--font-mono); }
.cell-muted { color: var(--text-2); }
.cell-symbol { display: flex; align-items: center; gap: 8px; font-weight: 600; }
.category-tag {
  font-size: 10px; padding: 2px 7px; border-radius: 999px; background: var(--bg-3); color: var(--text-1);
  font-family: var(--font-mono); letter-spacing: 0.3px;
}
.badge { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; padding: 2px 8px; border-radius: 999px; font-weight: 500; }
.badge-neutral { background: var(--bg-3); color: var(--text-2); }
.badge-bull { background: var(--bull-soft); color: var(--bull); }
.badge-bear { background: var(--bear-soft); color: var(--bear); }
.badge-pending { background: var(--violet-soft); color: var(--violet); }
.badge-warn { background: var(--warn-soft); color: var(--warn); }

.star-btn {
  width: 22px; height: 22px; display: inline-flex; align-items: center; justify-content: center;
  background: transparent; border: none; color: var(--text-2); border-radius: var(--radius-sm);
  transition: color var(--transition);
}
.star-btn:hover { color: var(--warn); }
.star-btn.is-active { color: var(--warn); }
.star-btn svg { width: 14px; height: 14px; }

.empty-state {
  flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 10px; padding: 40px 20px; color: var(--text-2); text-align: center;
}
.empty-state svg { width: 40px; height: 40px; opacity: 0.5; }
.empty-state-title { font-size: 13px; color: var(--text-1); font-weight: 600; }
.empty-state-desc { font-size: 12px; max-width: 320px; line-height: 1.5; }

/* ==========================================================================
   4. SETTINGS DRAWER
   ========================================================================== */
.settings-overlay {
  position: fixed; inset: 0; background: rgba(5,7,11,0.55); z-index: 40;
  opacity: 0; visibility: hidden; transition: opacity var(--transition), visibility var(--transition);
}
.settings-overlay.is-open { opacity: 1; visibility: visible; }

.settings-drawer {
  position: fixed; top: 0; right: 0; height: 100%; width: 360px; max-width: 92vw;
  background: var(--bg-1); border-left: 1px solid var(--border); z-index: 41;
  display: flex; flex-direction: column;
  transform: translateX(100%); transition: transform 220ms ease;
  box-shadow: -8px 0 24px rgba(0,0,0,0.35);
}
.settings-drawer.is-open { transform: translateX(0); }
.settings-drawer[hidden] { display: none; }

.drawer-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; border-bottom: 1px solid var(--border); }
.drawer-header h2 { font-size: 14px; margin: 0; font-weight: 600; }
.drawer-body { flex: 1; overflow-y: auto; padding: 4px 16px 16px; }
.drawer-footer { padding: 12px 16px; border-top: 1px solid var(--border); display: flex; gap: 8px; justify-content: flex-end; }

.settings-section { padding: 16px 0; border-bottom: 1px solid var(--border); }
.settings-section:last-child { border-bottom: none; }
.settings-section h3 {
  font-size: 11px; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-2);
  margin: 0 0 12px;
}
.field-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 7px 0; }
.field-label { font-size: 12.5px; color: var(--text-0); }
.field-hint { font-size: 11px; color: var(--text-2); margin-top: 2px; }
.field-control-full { width: 100%; padding: 7px 0; }

.switch { position: relative; display: inline-block; width: 36px; height: 20px; flex: 0 0 auto; }
.switch input { opacity: 0; width: 0; height: 0; }
.switch-track {
  position: absolute; inset: 0; background: var(--bg-3); border-radius: 999px; transition: background var(--transition);
}
.switch-track::before {
  content: ""; position: absolute; width: 14px; height: 14px; left: 3px; top: 3px; border-radius: 50%;
  background: var(--text-1); transition: transform var(--transition), background var(--transition);
}
.switch input:checked + .switch-track { background: var(--accent-soft); }
.switch input:checked + .switch-track::before { transform: translateX(16px); background: var(--accent); }

.checkbox-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
.checkbox-item { display: flex; align-items: center; gap: 7px; font-size: 12px; color: var(--text-1); }
.checkbox-item input { accent-color: var(--accent); }
.watchlist-quick-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }

/* ==========================================================================
   5. STATUS BAR
   ========================================================================== */
.status-bar {
  height: var(--statusbar-h); flex: 0 0 auto; background: var(--bg-1); border-top: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between; padding: 0 14px;
  font-size: 11px; color: var(--text-2); font-family: var(--font-mono);
}
.status-bar-group { display: flex; align-items: center; gap: 16px; }
.status-item { display: flex; align-items: center; gap: 5px; white-space: nowrap; }
.status-item .status-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--text-2); }
.status-item.is-live .status-dot { background: var(--bull); }
.status-item.is-warn .status-dot { background: var(--warn); }

/* ==========================================================================
   6. TOASTS
   ========================================================================== */
.toast-container {
  position: fixed; bottom: 40px; right: 14px; z-index: 60;
  display: flex; flex-direction: column; gap: 8px; width: 300px; max-width: 90vw;
}
.toast {
  background: var(--bg-2); border: 1px solid var(--border-light); border-left: 3px solid var(--accent);
  border-radius: var(--radius-sm); padding: 10px 12px; font-size: 12px; color: var(--text-0);
  box-shadow: 0 6px 18px rgba(0,0,0,0.35);
  animation: toast-in 200ms ease;
}
.toast.toast-success { border-left-color: var(--bull); }
.toast.toast-error { border-left-color: var(--bear); }
.toast.toast-warn { border-left-color: var(--warn); }
.toast-title { font-weight: 600; margin-bottom: 2px; }
.toast-desc { color: var(--text-2); font-size: 11.5px; }
@keyframes toast-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

/* ==========================================================================
   7. RESPONSIVE
   ========================================================================== */
@media (max-width: 900px) {
  .sidebar {
    position: fixed; top: var(--header-h); left: 0; bottom: var(--statusbar-h);
    z-index: 30; width: var(--sidebar-w); transform: translateX(-100%);
    transition: transform var(--transition);
  }
  .sidebar.is-mobile-open { transform: translateX(0); box-shadow: 8px 0 24px rgba(0,0,0,0.4); }
  .sidebar.is-collapsed { width: var(--sidebar-w); }
  .header-center { display: none; }
  .search-input { width: 140px; }
}
@media (max-width: 560px) {
  .header-clock { display: none; }
  .conn-label { display: none; }
  .panel-title { font-size: 13px; }
}

/* Visible keyboard focus */
a:focus-visible, button:focus-visible, input:focus-visible, select:focus-visible {
  outline: 2px solid var(--accent); outline-offset: 2px;
}
</style>
</head>
<body>

<!-- ==========================================================================
     LOADING SCREEN
     ========================================================================== -->
<div id="loading-screen" class="loading-screen">
  <div class="loading-content">
    <div class="loading-logo">
      <svg viewBox="0 0 64 64" fill="none">
        <circle cx="32" cy="32" r="30" stroke="#232936" stroke-width="2"/>
        <circle cx="32" cy="32" r="20" stroke="#232936" stroke-width="1"/>
        <circle cx="32" cy="32" r="10" stroke="#232936" stroke-width="1"/>
        <g class="sweep">
          <path d="M32 32 L32 2 A30 30 0 0 1 58 17 Z" fill="#00d4ff" fill-opacity="0.18"/>
          <line x1="32" y1="32" x2="32" y2="2" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
        </g>
        <circle cx="32" cy="32" r="3" fill="#00d4ff"/>
      </svg>
    </div>
    <div class="loading-title">DERIV<span>SCANNER</span></div>
    <div class="loading-status" id="loading-status-text">Initializing…</div>
    <div class="loading-bar"><div class="loading-bar-fill" id="loading-bar-fill"></div></div>
  </div>
</div>

<!-- ==========================================================================
     APP SHELL
     ========================================================================== -->
<div id="app" class="app" hidden>

  <!-- HEADER -->
  <header class="header">
    <div class="header-left">
      <button id="sidebar-toggle" class="icon-btn" aria-label="Toggle sidebar" title="Toggle sidebar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="brand"><span class="brand-mark"></span>Deriv<span class="brand-accent">Scanner</span></div>
    </div>
    <div class="header-center">
      <div class="market-status" id="market-status"><span class="dot"></span><span>Synthetic Indices &middot; 24/7 Market</span></div>
    </div>
    <div class="header-right">
      <div class="connection-indicator" id="connection-indicator" data-status="idle">
        <span class="conn-dot"></span>
        <span class="conn-label" id="conn-label">Disconnected</span>
      </div>
      <div class="header-clock" id="header-clock">--:--:--</div>
      <button id="settings-toggle" class="icon-btn" aria-label="Open settings" title="Settings">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
