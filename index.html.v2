            </div>
            <select class="select" id="setting-wick-tolerance">
              <option value="1">1% (strict)</option>
              <option value="2">2%</option>
              <option value="3">3% (default)</option>
              <option value="5">5%</option>
              <option value="8">8% (loose)</option>
            </select>
          </div>
          <div class="field-row">
            <div>
              <div class="field-label">Countdown length</div>
